# Ignore packaging metadata
*.egg-info/
dist/
build/

# Python cache/bytecode
__pycache__/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/

# Local state DBs (examples/runtime artifacts)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Local secrets (never commit real tokens/passwords)
/.env

# Runtime output artifacts
outputs/

# Ignore IDE settings
.idea/

# Ignore stale files inside Scweet/
Scweet/debug.log

# Not tracked in v5:
src/
tools/
